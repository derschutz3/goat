{
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "ignore": [
        "venv",
        ".git",
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ]
    }
  ],
  "hosting": {
    "public": "app/static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "chamados"
      }
    ]
  }
}
